---
import type { SoftwareProject } from "./software-data";

type Props = {
  project: SoftwareProject;
  class?: string;
  hero?: boolean;
};

const { project, hero = false } = Astro.props;
const className = Astro.props.class ?? "";
---

<div class:list={["flex flex-col w-full", className]}>
  <h2 class:list={[hero ? "text-4xl" : "text-2xl", "mb-4 mx-auto font-bold"]}>{project.name}</h2>
  <p class="mb-4 mx-auto text-slate-700">{project.description}</p>
  <div class="flex space-x-2 mb-6 mx-auto">
    {project.tags?.map((tag) => (
      <span class="inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-semibold text-foreground">{tag}</span>
    ))}
  </div>
  <div class="uppercase flex space-x-4 mx-auto">
    <a href={project.url} class="flex text-sm text-blue-900">
      <span class="mr-2">Deployment</span>
      <span aria-hidden="true">⊕</span>
    </a>
    <a href={project.github} class="flex text-sm text-blue-900">
      <span class="mr-2">Github Code</span>
      <span aria-hidden="true">⌁</span>
    </a>
  </div>
</div>
