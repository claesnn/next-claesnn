---
import AuthorInfo from "./AuthorInfo.astro";
import Project from "./software/Project.astro";
import { projects } from "./software/software-data";
---

<div class="mx-auto flex flex-col mt-8">
  <Project project={projects[0]} class="mx-auto mb-2" hero />
  <hr class="my-10" />
  <div class="space-y-6 divide-y lg:divide-y-0 lg:space-y-0 lg:grid lg:grid-cols-2 lg:gap-5 lg:divide-x">
    {projects.slice(1, 3).map((project) => <Project project={project} class="p-6" />)}
  </div>
  <hr class="my-10" />
  <div class="space-y-6 divide-y lg:divide-y-0 lg:space-y-0 lg:grid lg:grid-cols-2 lg:gap-5 lg:divide-x">
    {projects.slice(3, 5).map((project) => <Project project={project} class="p-6" />)}
  </div>
</div>
<div class="mx-auto p-8 bg-slate-50 max-w-xl rounded-xl mt-24">
  <AuthorInfo />
</div>
