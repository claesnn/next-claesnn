---
const papers = [
  {
    title:
      "Versatile microscale screening platform for improving recombinant protein production in Chinese hamster ovary cells",
    description:
      "In this project, we developed a screening platform in 96-deep well plates. The platform enabled semi-automated cell counting, high-throughput protein secretion evaluation using split-GFP and the plate format enabled fast transfection and screening.<br /><br />My contribution to the project included cloning of plasmids encoding genes related to protein production and secretion. Evaluating the system for testing improvement of protein production and secretion for difficult-to-express proteins.",
    tags: ["Split-GFP", "Celigo", "Deep Well Plates", "Duetz", "Transient transfection", "CHO", "Protein Secretion"],
    url: "https://pubmed.ncbi.nlm.nih.gov/26657798/",
    image: "/papers/0.webp",
  },
  {
    title:
      "Mammalian perfusion cultivation at high L-Arginine concentration for efficient production of recombinant protein by increasing perfusion filter transmission",
    description:
      "Co-authored Journal of Biotechnology paper on mammalian perfusion cultivation at high L-Arginine concentration. The work focuses on improving recombinant protein production by increasing perfusion filter transmission.",
    tags: ["Perfusion cultivation", "Bioreactors", "L-Arginine", "Filter transmission", "Recombinant protein", "Journal of Biotechnology"],
    url: "https://www.sciencedirect.com/science/article/abs/pii/S0168165624002529?via%3Dihub",
    image: "/papers/1.svg",
  },
];
---

<div class="bg-slate-50/80 px-2 py-6 sm:px-4" data-paper-carousel data-papers={JSON.stringify(papers)}>
  <div class="flex flex-col max-w-3xl mx-auto">
    <a href={papers[0].url} class="group" data-paper-link>
      <div class="rounded-lg border border-slate-200 bg-card text-card-foreground shadow-sm flex flex-col transition-colors group-hover:border-teal-700">
        <div class="flex flex-col space-y-2 border-b border-slate-200 p-5 sm:p-6">
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-teal-800">Publication</p>
          <h3 class="text-2xl font-bold leading-tight text-slate-950" data-paper-title>{papers[0].title}</h3>
        </div>
        <div class="p-5 sm:p-6">
          <img src={papers[0].image} width="160" height="160" class="mb-4 h-36 w-36 rounded-md border border-slate-200 object-cover sm:float-left sm:mb-2 sm:mr-5 sm:h-40 sm:w-40" alt={papers[0].title} data-paper-image />
          <p class="text-sm leading-7 text-slate-600" data-paper-description set:html={papers[0].description} />
          <div class="flex flex-row flex-wrap gap-2 mt-4" data-paper-tags>
            {papers[0].tags.map((tag) => <span class="inline-flex items-center rounded-md border border-teal-100 bg-teal-50 px-2.5 py-1 text-xs font-bold text-teal-900">{tag}</span>)}
          </div>
        </div>
      </div>
    </a>
    {papers.length > 1 && (
      <div class="mx-auto mt-4 place-items-center flex">
        <button class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-slate-200 bg-white text-sm font-bold text-slate-700 hover:bg-accent hover:text-accent-foreground" type="button" data-paper-prev aria-label="Previous paper">
          ←
        </button>
        <span class="mx-4 text-xs font-bold uppercase tracking-[0.16em] text-slate-500" data-paper-count>1/{papers.length}</span>
        <button class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-slate-200 bg-white text-sm font-bold text-slate-700 hover:bg-accent hover:text-accent-foreground" type="button" data-paper-next aria-label="Next paper">
          →
        </button>
      </div>
    )}
  </div>
</div>

<script>
  document.querySelectorAll("[data-paper-carousel]").forEach((carousel) => {
    const papers = JSON.parse(carousel.getAttribute("data-papers") || "[]");
    const link = carousel.querySelector("[data-paper-link]");
    const title = carousel.querySelector("[data-paper-title]");
    const image = carousel.querySelector("[data-paper-image]");
    const description = carousel.querySelector("[data-paper-description]");
    const tags = carousel.querySelector("[data-paper-tags]");
    const count = carousel.querySelector("[data-paper-count]");
    const prev = carousel.querySelector("[data-paper-prev]");
    const next = carousel.querySelector("[data-paper-next]");
    let index = Number(new URLSearchParams(window.location.search).get("paper") || "0");
    if (!Number.isFinite(index) || index < 0 || index >= papers.length) index = 0;

    function render() {
      const paper = papers[index];
      if (link) link.setAttribute("href", paper.url);
      if (title) title.textContent = paper.title;
      if (image) {
        image.setAttribute("src", paper.image);
        image.setAttribute("alt", paper.title);
      }
      if (description) description.innerHTML = paper.description;
      if (tags) {
        tags.innerHTML = paper.tags.map((tag: string) => `<span class="inline-flex items-center rounded-md border border-teal-100 bg-teal-50 px-2.5 py-1 text-xs font-bold text-teal-900">${tag}</span>`).join("");
      }
      if (count) count.textContent = `${index + 1}/${papers.length}`;
      const params = new URLSearchParams(window.location.search);
      params.set("paper", String(index));
      window.history.replaceState(null, "", `${window.location.pathname}?${params.toString()}`);
    }

    prev?.addEventListener("click", () => {
      index = (index - 1 + papers.length) % papers.length;
      render();
    });
    next?.addEventListener("click", () => {
      index = (index + 1) % papers.length;
      render();
    });
    render();
  });
</script>
