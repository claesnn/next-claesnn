---
import { imageMeta } from "../../lib/imageMeta";

const imageCount = 54;
const images = Array.from({ length: imageCount }, (_, i) => i);
---

<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3" data-photo-grid data-image-count={imageCount}>
  {images.map((i) => (
    <div class="group relative">
      <a href={`/photography/${i}`}>
        <img
          src={`/images/${i}-640.webp`}
          loading={i < 6 ? "eager" : "lazy"}
          height={imageMeta[i].height}
          width={640}
          alt={`Photography ${i}`}
          class="transition-opacity hover:opacity-90"
        />
      </a>
      <button
        type="button"
        data-lightbox-open={i}
        class="absolute inset-0 bg-black bg-opacity-0 hover:bg-opacity-20 transition-all flex items-center justify-center opacity-0 group-hover:opacity-100"
        aria-label={`Open image ${i} in lightbox`}
      >
        <span class="text-white text-2xl">Zoom</span>
      </button>
    </div>
  ))}
</div>

<div class="hidden fixed inset-0 bg-black bg-opacity-90 z-50 items-center justify-center" data-lightbox>
  <button type="button" class="absolute top-4 right-4 text-white text-2xl hover:text-gray-300 z-10" aria-label="Close lightbox" data-lightbox-close>×</button>
  <button type="button" class="absolute left-4 top-1/2 -translate-y-1/2 text-white text-4xl hover:text-gray-300 z-10" aria-label="Previous image" data-lightbox-prev>‹</button>
  <button type="button" class="absolute right-4 top-1/2 -translate-y-1/2 text-white text-4xl hover:text-gray-300 z-10" aria-label="Next image" data-lightbox-next>›</button>
  <div class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[90vw] h-[90vh] flex items-center justify-center">
    <img src="/images/0-1280.webp" alt="Photography 0" class="max-h-full max-w-full object-contain transition-opacity duration-300" data-lightbox-image />
  </div>
  <div class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white text-sm" data-lightbox-count>1 / {imageCount}</div>
</div>

<script>
  const grid = document.querySelector("[data-photo-grid]");
  const lightbox = document.querySelector("[data-lightbox]");
  const image = document.querySelector("[data-lightbox-image]");
  const count = document.querySelector("[data-lightbox-count]");
  const total = Number(grid?.getAttribute("data-image-count") || "0");
  let current = 0;

  function show(index: number) {
    current = (index + total) % total;
    image?.setAttribute("src", `/images/${current}-1280.webp`);
    image?.setAttribute("alt", `Photography ${current}`);
    if (count) count.textContent = `${current + 1} / ${total}`;
  }

  function open(index: number) {
    show(index);
    lightbox?.classList.remove("hidden");
    lightbox?.classList.add("flex");
    document.body.style.overflow = "hidden";
  }

  function close() {
    lightbox?.classList.add("hidden");
    lightbox?.classList.remove("flex");
    document.body.style.overflow = "";
  }

  document.querySelectorAll("[data-lightbox-open]").forEach((button) => {
    button.addEventListener("click", () => open(Number(button.getAttribute("data-lightbox-open"))));
  });
  document.querySelector("[data-lightbox-close]")?.addEventListener("click", close);
  document.querySelector("[data-lightbox-prev]")?.addEventListener("click", (event) => {
    event.stopPropagation();
    show(current - 1);
  });
  document.querySelector("[data-lightbox-next]")?.addEventListener("click", (event) => {
    event.stopPropagation();
    show(current + 1);
  });
  lightbox?.addEventListener("click", (event) => {
    if (event.target === lightbox) close();
  });
  document.addEventListener("keydown", (event) => {
    if (lightbox?.classList.contains("hidden")) return;
    if (event.key === "Escape") close();
    if (event.key === "ArrowLeft") show(current - 1);
    if (event.key === "ArrowRight") show(current + 1);
  });
</script>
