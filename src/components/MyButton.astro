<button
  type="button"
  class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium transition-colors bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4 py-2"
  data-counter-button
>
  Say to a client component in a server rendered page: <span class="ml-1" data-counter-value>0</span>
</button>

<script>
  document.querySelectorAll("[data-counter-button]").forEach((button) => {
    const value = button.querySelector("[data-counter-value]");
    let count = 0;

    button.addEventListener("click", () => {
      count += 1;
      if (value) value.textContent = String(count);
    });
  });
</script>
